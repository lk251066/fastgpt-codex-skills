CODEX_HOME=$HOME/.codex

# Required runtime paths
FASTGPT_HARNESS_DIR=/path/to/fastgpt/agent-harness
FASTGPT_FIREFOX_PROFILE=/path/to/playwright-or-firefox-profile
FASTGPT_BASE_URL=https://cloud.fastgpt.cn/api

# Optional direct auth
# FASTGPT_ADMIN_BEARER_TOKEN=
# FASTGPT_COOKIE=

# Optional login automation
FASTGPT_LOGIN_URL=https://cloud.fastgpt.cn/login
FASTGPT_LOGIN_USERNAME=__SET_AT_RUNTIME__
FASTGPT_LOGIN_PASSWORD=__SET_AT_RUNTIME__

# Optional app invocation
# FASTGPT_APP_API_KEY=
